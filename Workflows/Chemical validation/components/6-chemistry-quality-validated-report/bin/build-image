#!/usr/bin/env bash

# Check if jq is installed
if ! test -n "$(command -v jq)"; then
  echo "ERROR: jq not found, please look the dependencies section of the project README.md"
  exit 1
fi

# change directoy if argument is passed
if [ "$#" -eq  "1" ]
  then
    echo "Building image at '$1'"
    cd "$1"
fi

COL_BG_RED="\e[41m"
COL_RESET='\e[0m'
ANNOTATION_FILE="annotation.json"

# Check if annotation.json exists
if ! test -f "$ANNOTATION_FILE"; then
  echo -e "${COL_BG_RED}'annotation.json' is missing${COL_RESET}"
  exit 1
fi

# Get docker image and version from annotation.json
DOCKER_IMAGE=$(jq -r '.dockerImage // empty' < annotation.json)
DOCKER_IMAGE_VERSION=$(jq -r '.version // empty' < annotation.json)

# Check if docker image and version are set
if [[ -z "$DOCKER_IMAGE" ]]; then
  echo -e "${COL_BG_RED}'dockerImage' key is missing OR empty, please check the annotation JSON${COL_RESET}"
  exit 1
fi

if [[ -z "$DOCKER_IMAGE_VERSION" ]]; then
  echo -e "${COL_BG_RED}'version' key is missing OR empty, please check the annotation JSON${COL_RESET}"
  exit 1
fi

# Print docker image and version
echo "$DOCKER_IMAGE:$DOCKER_IMAGE_VERSION"

# Build image
docker build -t "$DOCKER_IMAGE:$DOCKER_IMAGE_VERSION" .
